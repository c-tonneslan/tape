# Copy to .env and fill in. .env is gitignored.

# Alpaca paper account. Get keys at https://app.alpaca.markets/paper/dashboard/overview
# The base URL must be the PAPER URL. The bot refuses to start with a live URL.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Optional: Anthropic key for the AI-augmented periphery (briefing, journaling).
# The bot runs fine without it; AI features just no-op.
ANTHROPIC_API_KEY=
